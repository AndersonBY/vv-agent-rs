{
  "create_error_cases": [
    {
      "arguments": {
        "agent_id": "\u001c",
        "task_description": "Research"
      },
      "expected": {
        "error": "`agent_id` is required",
        "error_code": "agent_id_required",
        "ok": false
      },
      "name": "portable_whitespace_agent_id_is_empty"
    },
    {
      "arguments": {
        "agent_id": "researcher",
        "task_description": "single",
        "tasks": [
          {
            "task_description": "batch"
          }
        ]
      },
      "expected": {
        "error": "`task_description` and `tasks` are mutually exclusive",
        "error_code": "sub_task_payload_conflict",
        "ok": false
      },
      "name": "single_and_batch_modes_conflict"
    },
    {
      "arguments": {
        "agent_id": "researcher"
      },
      "expected": {
        "error": "Provide either `task_description` or `tasks`",
        "error_code": "sub_task_payload_missing",
        "ok": false
      },
      "name": "task_payload_is_required"
    },
    {
      "arguments": {
        "agent_id": "researcher",
        "exclude_files_pattern": "(?=secret)",
        "task_description": "single"
      },
      "expected": {
        "error": "exclude_files_pattern must be a valid portable regular expression",
        "error_code": "invalid_exclude_files_pattern",
        "ok": false
      },
      "name": "lookaround_regex_is_rejected"
    },
    {
      "arguments": {
        "agent_id": "researcher",
        "exclude_files_pattern": "a{,3}",
        "task_description": "single"
      },
      "expected": {
        "error": "exclude_files_pattern must be a valid portable regular expression",
        "error_code": "invalid_exclude_files_pattern",
        "ok": false
      },
      "name": "python_only_open_range_quantifier_is_rejected"
    },
    {
      "arguments": {
        "agent_id": "researcher",
        "exclude_files_pattern": "a**",
        "task_description": "single"
      },
      "expected": {
        "error": "exclude_files_pattern must be a valid portable regular expression",
        "error_code": "invalid_exclude_files_pattern",
        "ok": false
      },
      "name": "rust_only_stacked_quantifier_is_rejected"
    }
  ],
  "early_error_metadata_matches_content": true,
  "failed_outcome_error_code": "sub_task_failed",
  "manager_outcome": {
    "lookup_task_id": "lookup",
    "outcome_task_id": "wire",
    "status_entry": {
      "agent_name": "researcher",
      "error": "child failed",
      "error_code": "sub_task_failed",
      "session_id": "wire-session",
      "status": "failed",
      "task_id": "lookup"
    },
    "unicode_preview": {
      "repeat": 100,
      "text": "文"
    }
  },
  "listener_identity": {
    "stale_session_events_ignored": true,
    "subscribe_failure_retry": true
  },
  "pending_interaction_previous_status": "pending",
  "status_success_cases": [
    {
      "arguments": {
        "task_ids": [
          "unknown"
        ]
      },
      "expected": {
        "detail_level": "basic",
        "suggested_next_check_after_seconds": 300,
        "tasks": [
          {
            "error": "Sub-task unknown not found.",
            "status": "missing",
            "task_id": "unknown"
          }
        ]
      },
      "name": "default_status_query"
    }
  ],
  "sync_failed_outcome": {
    "expected": {
      "agent_name": "researcher",
      "completion_reason": "failed",
      "cycles": 0,
      "error": "child failed",
      "error_code": "sub_task_failed",
      "final_answer": null,
      "partial_output": "last child draft",
      "resolved": {},
      "session_id": null,
      "status": "failed",
      "task_id": "failed-child",
      "todo_list": [],
      "wait_reason": null
    },
    "input_error_code": " "
  },
  "sync_wait_outcome": {
    "internal_error_code": null,
    "manager_status_error_code_field": "omitted",
    "sub_run_event_error_code_field": "omitted",
    "sync_single_tool_envelope_error_code": "sub_task_wait_user",
    "expected": {
      "agent_name": "researcher",
      "completion_reason": "wait_user",
      "completion_tool_name": "dangerous",
      "cycles": 1,
      "error": null,
      "error_code": "sub_task_wait_user",
      "final_answer": null,
      "partial_output": "proposed change",
      "resolved": {},
      "session_id": "wait-session",
      "status": "wait_user",
      "task_id": "wait-child",
      "todo_list": [],
      "wait_reason": "Approve dangerous."
    }
  },
  "worker_visibility": {
    "running_status_authoritative": true,
    "terminal_fields_hidden_until_worker_exit": true
  },
  "status_error_cases": [
    {
      "arguments": {
        "message": "continue",
        "task_ids": [
          "unknown"
        ]
      },
      "expected": {
        "details": {
          "task_id": "unknown"
        },
        "error": "Sub-task unknown not found.",
        "error_code": "sub_task_not_found",
        "ok": false
      },
      "name": "task_scoped_error_includes_task_id"
    }
  ],
  "status_envelope": {
    "lineage_fields": [
      "parent_run_id",
      "parent_tool_call_id"
    ],
    "recent_activity_when_unavailable": "omitted"
  },
  "validation": {
    "argument_validation_source": "builtin_tool_behavior.canonical.argument_validation",
    "handler_receives_schema_valid_arguments": true,
    "payload_mode_validation_precedes_exclude_pattern": true,
    "semantic_priority": [
      "runtime_availability",
      "agent_id_non_empty",
      "payload_mode",
      "exclude_pattern_semantics"
    ],
    "batch_item_shape": "schema_validated_before_handler",
    "top_level_output_requirements_scope": "single_only"
  }
}
