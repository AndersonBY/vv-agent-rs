  "transition_rules": {
    "allowed": [
      [
        "planned",
        "failed"
      ],
      [
        "planned",
        "started"
      ],
      [
        "started",
        "succeeded"
      ],
      [
        "started",
        "failed"
      ],
      [
        "started",
        "ambiguous"
      ],
      [
        "ambiguous",
        "planned"
      ],
      [
        "ambiguous",
        "succeeded"
      ],
      [
        "ambiguous",
        "failed"
      ]
    ],
    "terminal_receipts": [
      "succeeded",
      "failed"
    ],
    "cycle_commit_clears_committed_journals": true,
    "progress_write_preserves_active_claim": true,
    "request_digest_mismatch": "checkpoint_journal_integrity_mismatch_before_claim_without_state_transition",
    "retry_attempt": "previous_plus_one",
    "same_logical_retry_reuses_operation_id_and_idempotency_key": true
  },
  "outcome_classification": {
    "failed_requires_definitive_external_outcome": true,
    "pre_dispatch_local_failure": "planned_to_failed",
    "explicit_provider_or_tool_rejection": "started_to_failed",
    "timeout_after_started": "ambiguous_unless_the_adapter_proves_a_definitive_outcome",
    "cancellation_after_started": "ambiguous_unless_the_adapter_proves_a_definitive_outcome",
    "connection_loss_after_started": "ambiguous",
    "non_cooperative_blocking_tool_timeout": "ambiguous_even_if_the_waiting_runtime_returns",
    "framework_must_not_assume_a_timed_out_thread_or_process_stopped_side_effects": true
  },
  "pre_start_rules": {
    "approval_pending_may_remain_planned": true,
    "approval_grant_must_be_durable_before_started": true,
    "approval_denial_or_timeout_writes_started": false,
    "tool_policy_denial_writes_started": false,
    "before_tool_hook_short_circuit_writes_started": false,
    "approval_resume_uses_source_tool_call_id_request_digest_and_idempotency_key": true,
    "approval_resume_operation_id_is_stable_within_the_distinct_resume_run": true,
    "session_memory_compaction_and_ptl_requests_are_journaled_model_operations": true,
    "model_operation_and_dispatch_attempt_id_are_durable": true,
    "started_means_provider_may_or_may_not_have_received_request": true,
    "model_started_state_and_started_event_are_one_progress_cas": true,
    "terminal_model_state_ledger_budget_and_outbox_are_one_progress_cas": true,
    "ambiguous_recovery_ledger_budget_and_failed_event_are_one_progress_cas": true,
    "pre_dispatch_model_failure_adds_no_model_call_record": true,
    "receipt_replay_does_not_append_usage_or_budget": true
  },
  "model_call_accounting": {
    "identity_contract": {
      "fields": [
        "call_id",
        "operation_id",
        "attempt",
        "operation",
        "cycle_index",
        "backend",
        "model"
