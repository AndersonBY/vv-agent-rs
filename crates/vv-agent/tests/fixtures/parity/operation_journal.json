      "journal_operation_field": "model_operation",
      "other_record_operation_field": "operation",
      "backend_and_model_source": "actual_effective_dispatch",
      "root_run_definition_model_is_not_a_fallback": true,
      "journal_started_event_terminal_event_and_ledger_must_match": true,
      "missing_or_mismatch_error": "checkpoint_status_invalid"
    },
