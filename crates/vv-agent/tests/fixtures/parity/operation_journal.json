          "model_call_completed"
        ]
      },
      {
        "name": "terminal_with_budget_snapshot",
        "progress_cas": "terminal",
        "budget_configured": true,
        "budget_exhausted": false,
        "appended_event_types": [
          "model_call_completed",
          "budget_snapshot"
        ]
