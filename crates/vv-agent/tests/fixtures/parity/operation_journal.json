{
  "contract": "operation_journal",
  "version": 1,
  "enums": {
    "kinds": [
      "model",
      "tool"
    ],
    "states": [
      "planned",
      "started",
      "succeeded",
      "failed",
      "ambiguous"
    ],
    "idempotency_support": [
      "supported",
      "unsupported",
      "unknown"
    ],
    "reconciliation_decisions": [
      "defer",
      "retry",
      "replay_success",
      "record_failure",
      "abort"
    ]
  },
  "request_digest": {
    "schema_version": "vv-agent.operation-request.v1",
    "canonicalization": "RFC 8785 JSON Canonicalization Scheme over UTF-8 followed by lowercase SHA-256",
    "model_projection": "complete effective provider request after credential redaction, including model, messages, settings, tools, output schema, and provider idempotency key",
    "tool_projection": "tool call id, exact tool name, arguments, and framework idempotency key",
    "excluded_fields": [
      "operation_id",
      "cycle_index",
      "attempt",
      "credential_values"
    ],
    "retry_rule": "the same logical request keeps its digest while attempt increments; a changed effective request requires a new journal entry",
