        "budget_configured": true,
        "budget_exhausted": true,
        "appended_event_types": [
          "model_call_completed",
          "budget_exhausted"
        ]
      },
      {
        "name": "ambiguous_recovery_with_budget_snapshot",
        "progress_cas": "terminal_recovery",
        "budget_configured": true,
        "budget_exhausted": false,
        "appended_event_types": [
          "model_call_failed",
          "budget_snapshot"
        ]
      }
    ],
    "atomic_outbox_rules": {
      "events_are_appended_contiguously_in_listed_order": true,
      "terminal_model_event_precedes_budget_observation": true,
      "budget_exhausted_replaces_budget_snapshot_for_the_same_boundary": true,
      "budget_events_are_absent_when_no_budget_is_configured": true,
      "event_delivery_occurs_after_the_progress_cas": true
    },
