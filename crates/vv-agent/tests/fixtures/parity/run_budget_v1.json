{
  "contract": "run_budget_v1",
  "version": 1,
  "integer_bounds": {
    "minimum": 0,
    "maximum": 9007199254740991
  },
  "defaults": {
    "limits": null,
    "unavailable_metric_policy": "continue_and_mark",
    "empty_limits_are_unlimited": true
  },
  "enums": {
    "dimensions": [
      "total_tokens",
      "uncached_input_tokens",
      "tool_calls",
      "tool_calls_by_name",
      "wall_time",
      "host_cost"
    ],
    "boundaries": [
      "run_start",
      "cycle_start",
      "llm_complete",
      "tool_batch_preflight",
      "tool_batch_complete",
      "terminal"
    ],
    "exhaustion_reasons": [
      "limit_reached",
      "limit_exceeded",
      "metric_unavailable"
    ],
    "unavailable_reasons": [
      "usage_missing",
      "meter_missing",
      "meter_unavailable",
      "meter_error",
      "unit_mismatch",
      "currency_mismatch",
      "non_monotonic",
      "integer_overflow"
    ],
    "unavailable_metric_policies": [
      "continue_and_mark",
      "stop"
    ]
  },
  "dimension_precedence": [
    "wall_time",
    "total_tokens",
    "uncached_input_tokens",
    "host_cost",
    "tool_calls",
    "tool_calls_by_name"
  ],
  "wire_examples": {
