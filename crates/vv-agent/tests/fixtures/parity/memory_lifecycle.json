{
  "version": "memory_lifecycle",
  "summary_route": {
    "backend": "memory-backend",
    "model": "memory-model",
    "request_model": "memory-model",
    "resolution_count": 1
  },
  "session_extraction_route": {
    "backend": "session-memory-backend",
    "model": "session-memory-model",
    "request_model": "session-memory-model",
    "resolution_count": 1
  },
  "capacity_contract": {
    "configured_default_threshold": 250000,
    "unknown_context_window_strategy": {
      "planning_prompt_capacity": "configured_threshold > 0 ? configured_threshold : configured_default_threshold",
      "model_context_window": "min(planning_prompt_capacity + reserved_output_tokens + autocompact_buffer_tokens, u64_max)",
      "default_model_context_window": 279000
    },
    "context_window_resolution": {
      "precedence": [
        "positive_task_metadata.model_context_window",
        "resolved_model.context_length",
        "derived_planning_context"
      ],
      "non_positive_task_metadata_is_absent": true,
      "cases": [
        {
          "name": "zero_metadata_uses_resolved_capability",
          "input": {
            "task_metadata_model_context_window": 0,
            "resolved_model_context_window": 64000
          },
          "expected_model_context_window": 64000
        },
        {
          "name": "zero_metadata_without_resolved_capability_uses_derived_planning_context",
          "input": {
            "task_metadata_model_context_window": 0,
            "resolved_model_context_window": null,
            "configured_threshold": 250000,
            "reserved_output_tokens": 16000,
            "autocompact_buffer_tokens": 13000
          },
          "expected_model_context_window": 279000
        }
      ]
    },
    "reserved_output_tokens_fallback": 16000,
    "autocompact_buffer_tokens_default": 13000,
    "microcompact_trigger_ratio_default": 0.75,
    "resolved_model_max_output_is_capability_not_request_default": true,
    "reserved_output_precedence": [
      "effective_model_settings.max_tokens",
      "task_metadata.reserved_output_tokens",
      "framework_fallback"
    ],
    "reserved_output_source_values": [
      "model_settings",
      "task_metadata",
      "framework_fallback",
      "framework_fallback_capped_by_model_capability"
    ],
    "formula": {
      "derived_prompt_capacity": "max(model_context_window - reserved_output_tokens - autocompact_buffer_tokens, 0)",
      "effective_threshold": "configured_threshold > 0 ? min(configured_threshold, derived_prompt_capacity) : derived_prompt_capacity",
      "microcompact_threshold": "floor(effective_threshold * microcompact_trigger_ratio)",
      "known_zero_capacity_stays_zero": true
    },
    "cases": [
      {
        "name": "kimi_k3_uses_full_configured_ceiling",
        "input": {
          "configured_threshold": 250000,
          "model_context_window": 1048576,
          "effective_model_max_tokens": null,
          "task_metadata_reserved_output_tokens": null,
          "model_max_output_tokens": 1048576,
          "autocompact_buffer_tokens": 13000
        },
        "expected": {
          "reserved_output_tokens": 16000,
          "reserved_output_source": "framework_fallback",
          "effective_threshold": 250000,
          "microcompact_threshold": 187500
        }
      },
      {
        "name": "deepseek_v4_pro_uses_full_configured_ceiling",
        "input": {
          "configured_threshold": 250000,
          "model_context_window": 1000000,
          "effective_model_max_tokens": null,
          "task_metadata_reserved_output_tokens": null,
          "model_max_output_tokens": 384000,
          "autocompact_buffer_tokens": 13000
        },
        "expected": {
          "reserved_output_tokens": 16000,
          "reserved_output_source": "framework_fallback",
          "effective_threshold": 250000,
          "microcompact_threshold": 187500
        }
      },
      {
        "name": "explicit_request_limit_wins",
        "input": {
          "configured_threshold": 250000,
          "model_context_window": 256000,
          "effective_model_max_tokens": 4096,
          "task_metadata_reserved_output_tokens": 32000,
          "model_max_output_tokens": 256000,
          "autocompact_buffer_tokens": 13000
        },
        "expected": {
          "reserved_output_tokens": 4096,
          "reserved_output_source": "model_settings",
          "effective_threshold": 238904,
          "microcompact_threshold": 179178
        }
      },
      {
        "name": "explicit_host_reserve_wins_without_request_limit",
        "input": {
          "configured_threshold": 250000,
          "model_context_window": 256000,
          "effective_model_max_tokens": null,
          "task_metadata_reserved_output_tokens": 32768,
          "model_max_output_tokens": 256000,
          "autocompact_buffer_tokens": 13000
        },
        "expected": {
          "reserved_output_tokens": 32768,
          "reserved_output_source": "task_metadata",
          "effective_threshold": 210232,
          "microcompact_threshold": 157674
        }
      },
      {
        "name": "explicit_request_limit_is_not_capped_by_smaller_model_capability",
        "input": {
          "configured_threshold": 250000,
          "model_context_window": 64000,
          "effective_model_max_tokens": 24000,
          "task_metadata_reserved_output_tokens": null,
          "model_max_output_tokens": 4096,
          "autocompact_buffer_tokens": 13000
        },
        "expected": {
          "reserved_output_tokens": 24000,
          "reserved_output_source": "model_settings",
          "effective_threshold": 27000,
          "microcompact_threshold": 20250
        }
      },
      {
        "name": "explicit_host_reserve_is_not_capped_by_smaller_model_capability",
        "input": {
          "configured_threshold": 250000,
          "model_context_window": 64000,
          "effective_model_max_tokens": null,
          "task_metadata_reserved_output_tokens": 24000,
          "model_max_output_tokens": 4096,
          "autocompact_buffer_tokens": 13000
        },
        "expected": {
          "reserved_output_tokens": 24000,
          "reserved_output_source": "task_metadata",
          "effective_threshold": 27000,
          "microcompact_threshold": 20250
        }
      },
      {
        "name": "fallback_is_capped_by_smaller_model_capability",
        "input": {
          "configured_threshold": 250000,
          "model_context_window": 32000,
          "effective_model_max_tokens": null,
          "task_metadata_reserved_output_tokens": null,
          "model_max_output_tokens": 8192,
          "autocompact_buffer_tokens": 13000
        },
        "expected": {
          "reserved_output_tokens": 8192,
          "reserved_output_source": "framework_fallback_capped_by_model_capability",
          "effective_threshold": 10808,
          "microcompact_threshold": 8106
        }
      },
      {
        "name": "known_zero_capacity_stays_zero",
        "input": {
          "configured_threshold": 250000,
          "model_context_window": 10000,
          "effective_model_max_tokens": 10000,
          "task_metadata_reserved_output_tokens": null,
          "model_max_output_tokens": 10000,
          "autocompact_buffer_tokens": 13000
        },
        "expected": {
          "reserved_output_tokens": 10000,
          "reserved_output_source": "model_settings",
          "effective_threshold": 0,
          "microcompact_threshold": 0
        }
      }
    ]
  },
  "compaction_events": {
    "started": {
      "trigger_values": [
        "micro_threshold",
        "full_threshold",
        "prompt_too_long"
      ],
      "new_producer_fields": [
        "trigger",
        "configured_threshold",
        "effective_threshold",
        "microcompact_threshold",
        "model_context_window",
        "model_max_output_tokens",
        "reserved_output_tokens",
        "reserved_output_source",
        "autocompact_buffer_tokens"
      ]
    },
    "completed": {
      "mode_values": [
        "none",
        "micro",
        "structural",
        "summary",
        "emergency"
      ],
      "new_producer_fields": [
        "mode",
        "changed"
      ],
      "changed_is_content_aware": true,
      "mode_is_strongest_applied_stage": true
    },
    "simultaneous_warning_and_microcompact": {
      "order": [
        "microcompact_eligible_old_tool_results",
        "recalculate_effective_length",
        "append_memory_warning_only_if_post_microcompact_length_remains_eligible"
      ],
      "warning_uses_post_microcompact_length": true,
      "warning_must_not_prevent_eligible_microcompact": true
    },
    "provider_and_journal_share_event_identity": [
      "event_id",
      "created_at"
    ],
    "missing_or_unknown_fields_are_rejected": true,
    "unknown_enum_values_are_rejected": true,
    "task_semantics_are_not_inspected": true
  },
  "provider_attempts": {
    "prompt_too_long_failures_before_success": 2,
    "started_count": 2,
    "completed_count": 2,
    "strategies": [
      {
        "attempt": 1,
        "strategy": "forced",
        "drop_ratio": null
      },
      {
        "attempt": 2,
        "strategy": "emergency",
        "drop_ratio": 0.4
      }
    ],
    "result_metadata": {
      "phase": "before"
    },
    "before_error": {
      "stage": "before_compact",
      "error": "before exploded"
    },
    "after_error": {
      "stage": "after_compact",
      "error": "after exploded"
    }
  },
  "session_memory": {
    "stale_fact": "stale decision",
    "fresh_fact": "fresh decision",
    "block_count": 1,
    "initialized_after_compaction": true,
    "baseline_includes_injected_context": true
  },
  "artifacts": {
    "fallback_pattern": "^tool_result_[0-9a-f]{32}\\.txt$",
    "fallback_count": 2,
    "paths_are_distinct": true,
    "write_failure_path": "N/A",
    "escape_path": "N/A"
  }
}
