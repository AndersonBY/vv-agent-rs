      "base_golden_case": "minimal",
      "mutation": {
        "add": {
          "future_behavior": true
        }
      },
      "error_code": "checkpoint_definition_invalid"
    },
    {
      "name": "unstable_process_local_capability",
      "generated_input": {
        "behavior_field": "tool_policy.predicate",
        "process_local_callable": true,
        "stable_capability_ref": null
      },
      "error_code": "checkpoint_definition_unstable"
    },
    {
      "name": "unstable_process_local_hook",
      "generated_input": {
        "behavior_field": "runtime_hooks[0]",
        "process_local_callable": true,
        "stable_capability_ref": null
      },
      "error_code": "checkpoint_definition_unstable"
    },
    {
      "name": "behavior_metadata_without_reference",
      "generated_input": {
        "run_metadata": {
          "tenant_mode": "strict"
        },
        "stable_capability_ref": null
      },
      "error_code": "checkpoint_definition_unstable"
    },
    {
      "name": "non_finite_number",
      "generated_input": {
        "json_pointer": "/model/settings/temperature",
        "number_kind": "NaN"
      },
      "error_code": "checkpoint_definition_not_i_json"
    },
    {
      "name": "unsafe_integer",
      "generated_input": {
        "json_pointer": "/model/settings/extra_body/count",
        "value": 9007199254740992
      },
      "error_code": "checkpoint_definition_not_i_json"
    }
  ]
}
