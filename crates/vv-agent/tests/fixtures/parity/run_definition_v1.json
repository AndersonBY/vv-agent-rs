{
  "contract": "run_definition_v1",
  "version": 1,
  "schema_version": "vv-agent.run-definition.v1",
  "canonicalization": {
    "algorithm": "RFC 8785 JSON Canonicalization Scheme",
    "encoding": "UTF-8",
    "hash": "SHA-256",
    "digest_encoding": "lowercase_hex",
    "number_domain": "I-JSON finite IEEE-754 numbers and integers in -9007199254740991..9007199254740991",
    "reject_before_first_external_operation": true
  },
  "normalization": {
    "agent": "effective_name_and_type",
    "initial_shared_state": "caller_supplied_state_before_first_operation",
    "run_metadata": "public_behavior_affecting_metadata_only_runtime_owned_identity_and_capability_objects_excluded",
    "context_ref": "stable_capability_ref_or_null",
    "model_settings": "effective_after_provider_and_run_overrides",
    "extra_header_names": "ascii_lowercase",
    "extra_header_name_collision_after_lowercase": "checkpoint_definition_header_collision",
    "credential_slots": "sorted_unique_rfc6901_json_pointers_by_utf16_code_units_declared_by_provider_or_host",
    "credential_slot_escape": "rfc6901_tilde_zero_and_tilde_one_only",
    "credential_classification": "provider_or_host_must_declare_complete_before_external_operations",
    "credential_slot_value_replacement": "<credential-redacted>",
    "undeclared_sensitive_provider_value": "checkpoint_definition_sensitive_value_unclassified",
    "tools_order": "preserve_exact_model_visible_order",
    "tool_policy_name_lists": "sorted_unique",
    "extensions_order": "namespace_lexicographic",
    "initial_messages_order": "preserve",
    "behavior_affecting_process_local_capability_without_stable_ref": "checkpoint_definition_unstable",
    "nonempty_behavior_affecting_run_metadata_without_stable_ref": "checkpoint_definition_unstable"
  },
  "top_level_field_policy": {
    "closed": true,
    "unknown_field_error": "checkpoint_definition_invalid",
    "reason": "ignoring a behavior field would permit cross-language digest drift"
  },
  "capability_reference_policy": {
    "shape": {
      "id": "non_empty_string",
      "version": "non_empty_string"
    },
    "required_for_process_local_behavior": [
      "model_provider",
      "context_object",
      "context_provider",
      "memory_provider",
      "input_guardrail",
      "output_guardrail",
      "runtime_hook",
      "approval_provider",
      "approval_broker",
      "host_cost_meter",
      "reconciliation_provider",
      "behavior_affecting_run_metadata"
    ],
    "observational_event_sinks_and_tracers_may_be_excluded": true
  },
  "required_fields": [
    "schema_version",
    "agent",
    "root_input",
    "compiled_prompt",
    "initial_messages",
    "initial_shared_state",
    "run_metadata",
    "context_ref",
    "model",
    "credential_slots",
    "runtime_controls",
    "tools",
    "tool_policy",
    "checkpoint_policy",
    "budget_limits",
    "output_schema",
    "workspace_ref",
    "session_ref",
    "extensions",
    "capability_refs"
  ],
  "excluded_fields": [
    "credential_values",
    "checkpoint_store_location",
    "checkpoint_key",
    "run_id",
    "trace_id",
    "task_id",
    "claim_token",
    "lease",
    "event_cursor"
  ],
  "golden_cases": [
