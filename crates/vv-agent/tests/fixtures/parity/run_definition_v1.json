    {
      "name": "full_unicode_float_and_capabilities",
      "definition": {
        "schema_version": "vv-agent.run-definition.v1",
        "agent": {
          "name": "records-agent",
          "type": "workflow"
        },
        "root_input": "核对 café 订单 42。",
        "compiled_prompt": "Use tools carefully.\nDo not guess.",
        "initial_messages": [
          {
            "role": "user",
