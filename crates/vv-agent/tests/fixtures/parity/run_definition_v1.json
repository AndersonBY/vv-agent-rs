  "producer_cases": [
    {
      "name": "credential_rotation_preserves_digest",
      "base_golden_case": "full_unicode_float_and_capabilities",
      "mutation_stage": "before_credential_redaction",
      "mutation": {
        "replace_json_pointer": "/model/settings/extra_headers/authorization",
        "value": "Bearer rotated-secret"
      },
      "expected_digest_relation": "equal"
    },
    {
      "name": "semantic_header_changes_digest",
      "base_golden_case": "full_unicode_float_and_capabilities",
      "mutation": {
        "replace_json_pointer": "/model/settings/extra_headers/x-feature",
        "value": "reasoning-v3"
      },
      "expected_digest_relation": "different"
    },
    {
      "name": "tool_policy_set_reordering_is_normalized",
      "base_golden_case": "full_unicode_float_and_capabilities",
      "mutation_stage": "before_set_normalization",
      "mutation": {
        "replace_json_pointer": "/tool_policy/allowed_tools",
        "value": [
          "write_record",
          "read_record",
          "write_record"
        ]
      },
      "expected_digest_relation": "equal"
    },
    {
      "name": "model_visible_tool_reordering_changes_digest",
      "base_golden_case": "full_unicode_float_and_capabilities",
      "mutation": {
        "swap_array_indices": {
          "json_pointer": "/tools",
          "left": 0,
          "right": 1
        }
      },
      "expected_digest_relation": "different"
    },
    {
      "name": "capability_version_changes_digest",
      "base_golden_case": "full_unicode_float_and_capabilities",
      "mutation": {
        "replace_json_pointer": "/capability_refs/context_provider.primary/version",
        "value": "5"
      },
      "expected_digest_relation": "different"
    },
    {
      "name": "credential_slots_use_utf16_code_unit_order",
      "generated_input": {
        "unsorted": [
          "/model/settings/extra_body/\ue000",
          "/model/settings/extra_body/😀"
        ],
        "expected_sorted": [
          "/model/settings/extra_body/😀",
          "/model/settings/extra_body/\ue000"
        ]
      }
    },
    {
      "name": "credential_slot_rfc6901_escapes_resolve",
      "generated_input": {
        "object": {
          "a/b~c": "<credential-redacted>"
        },
        "pointer": "/a~1b~0c",
        "expected_value": "<credential-redacted>"
      }
    }
  ],
