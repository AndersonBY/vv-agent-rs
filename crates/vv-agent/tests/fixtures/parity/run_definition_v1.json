          "no_tool_policy": "continue",
          "memory_compact_threshold": 128000,
          "memory_threshold_percentage": 90,
          "allow_interruption": true,
          "native_multimodal": false,
          "tool_use_behavior": "run_llm_again",
          "stop_at_tool_names": []
        },
        "tools": [],
        "tool_policy": {
          "allowed_tools": null,
          "disallowed_tools": [],
          "approval": "default",
          "predicate_ref": null,
          "approval_timeout_seconds": null
        },
        "checkpoint_policy": {
          "ambiguous_model_policy": "require_reconciliation",
          "ambiguous_tool_policy": "require_reconciliation",
