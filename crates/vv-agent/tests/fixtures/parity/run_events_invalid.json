{
  "contract": "run_events_invalid",
  "rules": {
    "version": "v1",
    "unknown_top_level_fields": "reject",
    "unknown_event_types": "reject",
    "completion_fields": {
      "completion_reason": {
        "type": "string_or_null",
        "values": [
          "tool_finish",
          "no_tool_finish",
          "stop_on_first_tool",
          "stop_at_tool_name",
          "wait_user",
          "max_cycles",
          "cancelled",
          "failed",
          "budget_exhausted"
        ],
        "unknown_values": "reject"
      },
      "completion_tool_name": {
        "type": "string_or_null"
      },
      "partial_output": {
        "type": "string_or_null"
      }
    },
    "budget_fields": {
      "budget_usage": "object_or_null",
      "budget_exhaustion": "object_or_null",
      "enforcement_boundary_values": [
        "run_start",
        "cycle_start",
        "model_call_complete",
        "tool_batch_preflight",
        "tool_batch_complete",
        "terminal"
      ],
      "wire_integer_maximum": 9007199254740991
    },
    "stream_fields": {
      "delta": "string",
      "tool_call_id": "non_empty_string",
      "tool_name": "non_empty_string",
      "optional_counters": "non_negative_json_safe_integer"
    },
    "model_call_fields": {
      "event_types": [
        "model_call_started",
        "model_call_completed",
        "model_call_failed"
      ],
      "operations": [
        "agent_cycle",
        "session_memory",
        "memory_compaction"
      ],
      "failure_outcomes": [
        "definitive",
        "ambiguous"
      ],
      "record_status_mapping": {
        "model_call_completed": "completed",
        "model_call_failed:definitive": "failed",
        "model_call_failed:ambiguous": "ambiguous"
      },
      "call_id_and_operation_id": "non_empty_string",
      "attempt": "positive_json_safe_integer",
      "cycle_index": "positive_json_safe_integer",
      "backend_and_model": "non_empty_string",
      "terminal_usage": "closed_vv-agent.token-usage.v1",
      "failed_error_code": "non_empty_string",
      "prompts_outputs_and_error_bodies": "forbidden"
    },
    "compaction_fields": {
      "started_trigger_values": [
        "micro_threshold",
        "full_threshold",
        "prompt_too_long"
      ],
      "completed_mode_values": [
        "none",
        "micro",
        "structural",
        "summary",
        "emergency"
      ],
      "reserved_output_source_values": [
        "model_settings",
        "task_metadata",
        "framework_fallback",
        "framework_fallback_capped_by_model_capability"
      ],
      "capacity_counters": "non_negative_json_safe_integer_or_null",
      "changed": "boolean",
      "missing_required_fields": "reject"
    },
    "tool_lifecycle_fields": {
      "event_types": [
        "tool_call_planned",
        "tool_call_started",
        "tool_call_completed"
      ],
      "tool_call_id": "non_empty_string",
      "tool_name": "non_empty_string",
      "planned_and_started_arguments": "object",
      "tool_metadata": "omitted_or_closed_tool_metadata_object",
      "completed_status_values": [
        "success",
        "error",
        "wait_response",
        "running",
        "pending_compress"
      ],
      "completed_directive_values": [
        "continue",
        "finish",
        "wait_user"
      ],
      "completed_error_code": "string_or_null",
      "completed_execution_started": "boolean",
      "completed_duration_ms": "non_negative_json_safe_integer_or_null",
      "missing_required_completed_fields": "reject"
    }
  },
