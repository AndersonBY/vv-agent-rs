{
  "contract": "run_events_v1_invalid",
  "rules": {
    "version": "v1",
    "unknown_top_level_fields": "ignore",
    "unknown_event_types": "reject",
    "legacy_created_at_ms": "read_and_canonicalize",
    "legacy_approved": "read_and_derive_action",
    "completion_fields": {
      "completion_reason": {
        "type": "string_or_null",
        "values": [
          "tool_finish",
          "no_tool_finish",
          "stop_on_first_tool",
          "stop_at_tool_name",
          "wait_user",
          "max_cycles",
          "cancelled",
          "failed",
          "budget_exhausted"
        ],
        "unknown_values": "reject"
      },
      "completion_tool_name": {
        "type": "string_or_null"
      },
      "partial_output": {
        "type": "string_or_null"
      }
    },
    "budget_fields": {
      "budget_usage": "object_or_null",
      "budget_exhaustion": "object_or_null",
      "enforcement_boundary_values": [
        "run_start",
        "cycle_start",
        "llm_complete",
        "tool_batch_preflight",
        "tool_batch_complete",
        "terminal"
      ],
      "wire_integer_maximum": 9007199254740991
    },
    "stream_fields": {
      "delta": "string",
      "tool_call_id": "non_empty_string",
      "tool_name": "non_empty_string",
      "optional_counters": "non_negative_json_safe_integer"
    },
    "tool_lifecycle_fields": {
      "event_types": [
        "tool_call_planned",
        "tool_call_started",
        "tool_call_completed"
      ],
      "tool_call_id": "non_empty_string",
      "tool_name": "non_empty_string",
      "planned_and_started_arguments": "object",
      "tool_metadata": "omitted_or_closed_tool_metadata_object",
      "completed_status_values": [
        "success",
        "error",
        "wait_response",
        "running",
        "pending_compress"
      ],
      "completed_directive_values": [
        "continue",
        "finish",
        "wait_user"
      ],
      "completed_error_code": "string_or_null",
      "completed_execution_started": "boolean",
      "completed_duration_ms": "non_negative_json_safe_integer_or_null",
      "legacy_missing_additive_completed_fields": "accept_without_fabricating_values"
    }
  },
