{
  "contract": "run_events_v1_invalid",
  "rules": {
    "version": "v1",
    "unknown_top_level_fields": "ignore",
    "unknown_event_types": "reject",
    "legacy_created_at_ms": "read_and_canonicalize",
    "legacy_approved": "read_and_derive_action",
    "completion_fields": {
      "completion_reason": {
        "type": "string_or_null",
        "values": [
          "tool_finish",
          "no_tool_finish",
          "stop_on_first_tool",
          "stop_at_tool_name",
          "wait_user",
          "max_cycles",
          "cancelled",
          "failed",
          "budget_exhausted"
        ],
        "unknown_values": "reject"
      },
      "completion_tool_name": {
        "type": "string_or_null"
      },
      "partial_output": {
        "type": "string_or_null"
      }
    }
  },
  "canonicalize": [
    {
      "id": "unknown_top_level_field_is_ignored",
      "input": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_forward",
        "run_id": "run_forward",
        "trace_id": "trace_forward",
        "created_at": 123.456789,
        "input": "hello",
        "future_field": {
          "ignored": true
        }
      },
      "output": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_forward",
        "run_id": "run_forward",
        "trace_id": "trace_forward",
        "created_at": 123.456789,
        "input": "hello"
      }
    },
    {
      "id": "legacy_created_at_ms_is_seconds",
      "input": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_legacy_time",
        "run_id": "run_legacy_time",
        "trace_id": "trace_legacy_time",
        "created_at_ms": 123456.789,
        "input": "hello"
      },
      "output": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_legacy_time",
        "run_id": "run_legacy_time",
        "trace_id": "trace_legacy_time",
        "created_at": 123.456789,
        "input": "hello"
      }
    },
    {
      "id": "legacy_approval_true_derives_allow",
      "input": {
        "version": "v1",
        "type": "approval_resolved",
        "event_id": "evt_legacy_approval",
        "run_id": "run_legacy_approval",
        "trace_id": "trace_legacy_approval",
        "created_at": 123.456789,
        "request_id": "approval_legacy",
        "tool_name": "shell",
        "tool_call_id": "call_legacy",
        "approved": true
      },
      "output": {
        "version": "v1",
        "type": "approval_resolved",
        "event_id": "evt_legacy_approval",
        "run_id": "run_legacy_approval",
        "trace_id": "trace_legacy_approval",
        "created_at": 123.456789,
        "request_id": "approval_legacy",
        "tool_name": "shell",
        "tool_call_id": "call_legacy",
        "action": "allow",
        "approved": true
      }
    },
    {
      "id": "legacy_approval_false_derives_deny",
      "input": {
        "version": "v1",
        "type": "approval_resolved",
        "event_id": "evt_legacy_denial",
        "run_id": "run_legacy_denial",
        "trace_id": "trace_legacy_denial",
        "created_at": 123.456789,
        "request_id": "approval_legacy_denial",
        "tool_name": "shell",
        "tool_call_id": "call_legacy_denial",
        "approved": false
      },
      "output": {
        "version": "v1",
        "type": "approval_resolved",
        "event_id": "evt_legacy_denial",
        "run_id": "run_legacy_denial",
        "trace_id": "trace_legacy_denial",
        "created_at": 123.456789,
        "request_id": "approval_legacy_denial",
        "tool_name": "shell",
        "tool_call_id": "call_legacy_denial",
        "action": "deny",
        "approved": false
      }
    }
  ],
  "reject": [
    {
      "id": "missing_version",
      "input": {
        "type": "run_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "input": "hello"
      }
    },
    {
      "id": "unsupported_version",
      "input": {
        "version": "v2",
        "type": "run_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "input": "hello"
      }
    },
    {
      "id": "unknown_event_type",
      "input": {
        "version": "v1",
        "type": "mystery",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0
      }
    },
    {
      "id": "missing_event_id",
      "input": {
        "version": "v1",
        "type": "run_started",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "input": "hello"
      }
    },
    {
      "id": "empty_event_id",
      "input": {
        "version": "v1",
        "type": "run_started",
        "event_id": "",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "input": "hello"
      }
    },
    {
      "id": "non_string_run_id",
      "input": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_invalid",
        "run_id": 7,
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "input": "hello"
      }
    },
    {
      "id": "empty_trace_id",
      "input": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "",
        "created_at": 1.0,
        "input": "hello"
      }
    },
    {
      "id": "missing_created_at",
      "input": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "input": "hello"
      }
    },
    {
      "id": "negative_created_at",
      "input": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": -1.0,
        "input": "hello"
      }
    },
    {
      "id": "boolean_cycle_index",
      "input": {
        "version": "v1",
        "type": "cycle_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "cycle_index": true
      }
    },
    {
      "id": "negative_cycle_index",
      "input": {
        "version": "v1",
        "type": "cycle_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "cycle_index": -1
      }
    },
    {
      "id": "metadata_is_not_an_object",
      "input": {
        "version": "v1",
        "type": "run_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "input": "hello",
        "metadata": []
      }
    },
    {
      "id": "tool_arguments_are_not_an_object",
      "input": {
        "version": "v1",
        "type": "tool_call_started",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "tool_name": "search",
        "tool_call_id": "call_invalid",
        "arguments": 7
      }
    },
    {
      "id": "approval_action_conflicts_with_approved",
      "input": {
        "version": "v1",
        "type": "approval_resolved",
        "event_id": "evt_invalid",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1.0,
        "request_id": "approval_invalid",
        "tool_name": "shell",
        "tool_call_id": "call_invalid",
        "action": "timeout",
        "approved": true
      }
    },
    {
      "id": "unknown_completion_reason",
      "input": {
        "version": "v1",
        "type": "run_completed",
        "event_id": "evt_invalid_completion_reason",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1,
        "status": "completed",
        "final_output": "done",
        "completion_reason": "future_reason"
      }
    },
    {
      "id": "completion_reason_is_not_a_string_or_null",
      "input": {
        "version": "v1",
        "type": "run_completed",
        "event_id": "evt_invalid_completion_reason_type",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1,
        "status": "completed",
        "final_output": "done",
        "completion_reason": 7
      }
    },
    {
      "id": "completion_tool_name_is_not_a_string_or_null",
      "input": {
        "version": "v1",
        "type": "run_completed",
        "event_id": "evt_invalid_completion_tool_name_type",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1,
        "status": "completed",
        "final_output": "done",
        "completion_tool_name": false
      }
    },
    {
      "id": "partial_output_is_not_a_string_or_null",
      "input": {
        "version": "v1",
        "type": "run_completed",
        "event_id": "evt_invalid_partial_output_type",
        "run_id": "run_invalid",
        "trace_id": "trace_invalid",
        "created_at": 1,
        "status": "completed",
        "final_output": "done",
        "partial_output": {
          "text": "draft"
        }
      }
    }
  ]
}
