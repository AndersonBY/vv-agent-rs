    "recipe": {
      "settings_file": "/srv/settings.json",
      "backend": "deepseek",
      "model": "model-x",
      "workspace": "/srv/workspace",
      "timeout_seconds": 120,
      "log_preview_chars": 256,
      "state_store": {
        "kind": "redis",
        "location": "redis://state/0"
      },
      "capabilities": {
        "toolset_ref": {
          "id": "vv-agent.builtin-tools",
          "version": "1",
          "schema_digest": "f85422117d41d28ffa3cdfcfd9a42892854de624808fadc2124f4ebe7a452b61"
        },
        "tool_policy": {
