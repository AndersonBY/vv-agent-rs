  "invalid_cases": [
    {
      "name": "unsupported_schema_version",
      "path": [
        "schema_version"
      ],
      "value": "vv-agent.distributed-run.v3",
      "error": "unsupported distributed schema_version"
    },
    {
      "name": "missing_run_definition_schema",
      "path": [
        "run_definition_schema"
      ],
      "value": null,
      "error": "checkpoint_definition_schema_unsupported"
    },
    {
      "name": "unsupported_run_definition_schema",
      "path": [
        "run_definition_schema"
      ],
      "value": "vv-agent.run-definition.v2",
      "error": "checkpoint_definition_schema_unsupported"
    },
    {
      "name": "missing_checkpoint_config",
      "path": [
        "checkpoint_config"
      ],
      "value": null,
      "error": "distributed v2 requires checkpoint_config"
    },
    {
      "name": "missing_checkpoint_store_ref",
      "path": [
        "recipe",
        "capabilities",
        "checkpoint_store_ref"
      ],
      "value": null,
      "error": "distributed v2 requires checkpoint_store_ref"
    },
    {
      "name": "missing_required_extension_ref",
      "path": [
        "recipe",
        "capabilities",
        "checkpoint_extension_refs"
      ],
      "value": [],
      "error": "required checkpoint extension com.example.audit is unavailable"
    },
    {
      "name": "missing_after_cycle_hook_ref",
      "path": [
        "recipe",
        "capabilities",
        "after_cycle_hook_refs"
      ],
      "value": [
        {
          "id": "lifecycle.missing",
          "version": "1"
        }
      ],
      "error": "unknown distributed capability after_cycle_hook lifecycle.missing@1"
    },
    {
      "name": "definition_digest_mismatch",
      "path": [
        "run_definition_digest"
      ],
      "value": "dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
      "stored_value": "cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "error": "checkpoint_definition_mismatch"
    },
    {
      "name": "resume_attempt_mismatch",
      "path": [
        "resume_attempt"
      ],
      "value": 3,
      "stored_value": 2,
      "error": "checkpoint_resume_attempt_mismatch"
    },
    {
      "name": "missing_claim_mode",
      "path": [
        "claim_mode"
      ],
      "value": null,
      "error": "checkpoint_claim_mode_invalid"
    },
    {
      "name": "unknown_claim_mode",
      "path": [
        "claim_mode"
      ],
      "value": "retry",
      "error": "checkpoint_claim_mode_invalid"
    },
    {
      "name": "unsafe_extension_limit",
      "path": [
        "checkpoint_config",
        "max_extension_state_bytes"
      ],
      "value": 9007199254740992,
      "error": "max_extension_state_bytes must be between 0 and 9007199254740991"
    }
  ],
  "worker_rules": {
    "capability_resolution_before_claim": true,
    "after_cycle_hook_resolution_before_claim": true,
    "initial_claim_renewal_before_operations": true,
    "operation_progress_cas_preserves_claim": true,
    "heartbeat_updates_lease_only": true,
    "heartbeat_cannot_overwrite_journal": true,
    "reconciliation_provider_is_optional": true,
    "missing_reconciliation_provider_defaults_to_defer": true,
    "effective_claim_mode_uses_envelope_transport_metadata_and_stored_checkpoint": true,
    "terminal_commit_order": [
      "output_guardrail",
      "session_add_items_once",
      "session_persisted_observation",
      "terminal_event_outbox_pending",
      "checkpoint_terminal_finalize",
      "terminal_event_delivery",
      "terminal_event_delivery_recorded",
      "terminal_acknowledge_retained",
      "scheduler_acknowledgement"
    ],
    "terminal_acknowledgement_does_not_delete": true,
    "apalis_blocking_runtime": "tokio_spawn_blocking"
  },
  "redelivery_cases": [
    {
      "name": "live_claim",
      "expected": {
        "status": "in_progress",
        "resume_attempt_unchanged": true,
        "model_calls": 0,
        "tool_calls": 0
      }
    },
    {
      "name": "expired_started_unknown_tool",
      "expected": {
        "status": "reconciliation_required",
        "missing_reconciliation_provider_decision": "defer",
        "model_calls": 0,
        "tool_calls": 0
      }
    },
    {
      "name": "committed_receipt",
      "expected": {
        "operation_replayed": true,
        "external_calls": 0
      }
    },
    {
      "name": "committed_cycle",
      "expected": {
        "dispatch_cycle": 3,
        "next_envelope_claim_mode": "continue"
      }
    },
    {
      "name": "committed_terminal",
      "expected": {
        "terminal_replayed": true,
        "external_calls": 0
      }
    }
  ]
}
