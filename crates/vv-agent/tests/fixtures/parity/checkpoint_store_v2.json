{
  "contract": "checkpoint_store_v2",
  "version": 2,
  "run_definition_schema": "vv-agent.run-definition.v1",
  "run_definition_storage": "credential_redacted_object_embedded_and_immutable_beside_matching_digest",
  "namespaces": {
    "sqlite_table": "checkpoints",
    "redis_key_prefix": "vv-agent:checkpoint:",
    "redis_key_suffix": "lowercase_sha256_of_checkpoint_key"
  },
  "redis_key_vectors": [
    {
      "checkpoint_key": "tenant-7/run-42",
      "checkpoint_key_utf8_sha256": "900c4d195b6e2d16f4ac0725d2306d5b9685397249d4581e107769f38cb068c7",
      "data_key": "vv-agent:checkpoint:900c4d195b6e2d16f4ac0725d2306d5b9685397249d4581e107769f38cb068c7",
      "lease_key": "vv-agent:checkpoint:900c4d195b6e2d16f4ac0725d2306d5b9685397249d4581e107769f38cb068c7:lease"
    },
    {
      "checkpoint_key": "研究/运行-42",
      "checkpoint_key_utf8_sha256": "e6b1a2e6f36de6d5273e0ea9b2617ed36e49d0663668dd4cd30ea1091b0d974c",
      "data_key": "vv-agent:checkpoint:e6b1a2e6f36de6d5273e0ea9b2617ed36e49d0663668dd4cd30ea1091b0d974c",
      "lease_key": "vv-agent:checkpoint:e6b1a2e6f36de6d5273e0ea9b2617ed36e49d0663668dd4cd30ea1091b0d974c:lease"
    }
  ],
  "operations": [
    {
      "name": "create",
      "atomic": "insert_if_absent"
    },
    {
      "name": "load",
      "atomic": "read_one"
    },
    {
      "name": "claim",
      "atomic": "compare_status_cycle_and_lease_then_claim_and_increment_resume_attempt_only_for_recovery_mode"
    },
    {
      "name": "renew",
      "atomic": "compare_claim_token_and_live_lease_then_update_lease_only"
    },
    {
      "name": "progress",
      "atomic": "compare_revision_and_claim_token_then_update_payload_and_revision_preserving_claim"
    },
    {
      "name": "suspend",
      "atomic": "compare_revision_and_claim_token_then_persist_resumable_interruption_preserve_journals_and_clear_claim"
    },
    {
      "name": "commit_cycle",
      "atomic": "compare_revision_and_claim_token_then_commit_cycle_clear_journals_and_claim"
    },
    {
      "name": "finalize_claimed",
      "atomic": "compare_revision_and_claim_token_then_write_terminal_clear_claim_and_clear_ordinary_journals"
    },
    {
      "name": "finalize",
      "atomic": "compare_revision_and_no_claim_then_write_terminal_preserving_explicit_operator_abort_ambiguity"
    },
    {
      "name": "record_event_delivery",
      "atomic": "compare_revision_claim_and_pending_event_identity_then_record_cursor_preserving_claim_or_terminal"
    },
    {
      "name": "acknowledge_terminal",
      "atomic": "compare_revision_and_terminal_then_mark_acknowledged_without_delete"
    },
    {
      "name": "delete",
      "atomic": "explicit_host_retention_cleanup"
    }
  ],
  "revision_rules": {
    "create": 0,
    "claim_increment": 1,
    "progress_increment": 1,
    "suspend_increment": 1,
    "cycle_commit_increment": 1,
    "claimed_finalize_increment": 1,
    "finalize_increment": 1,
    "event_delivery_increment": 1,
    "renew_increment": 0,
    "acknowledge_increment": 1,
    "heartbeat_requires_revision": false,
    "heartbeat_requires_claim_token": true,
    "progress_preserves_claim": true,
    "claim_modes": [
      "continue",
      "recovery"
    ],
    "continue_claim_preserves_resume_attempt": true,
    "successful_recovery_claim_increments_resume_attempt": true,
    "failed_recovery_claim_preserves_resume_attempt": true,
    "claimable_statuses": [
      "running",
      "reconciliation_required"
    ],
    "successful_claim_sets_status_running": true,
    "suspend_preserves_active_journals": true,
    "suspend_clears_claim_without_advancing_cycle": true,
    "claimed_finalize_clears_claim_atomically": true,
    "event_delivery_preserves_claim_and_terminal": true,
    "outbox_event_ids_unique": true,
    "identical_event_enqueue_reuses_existing_entry": true,
    "conflicting_event_enqueue_error": "event_identity_conflict",
    "run_definition_and_digest_immutable_after_create": true,
    "operator_abort_finalize_preserves_ambiguous_journal": true
  },
  "event_payload_digest": {
    "canonicalization": "RFC 8785 JSON Canonicalization Scheme over the complete event object followed by lowercase SHA-256",
    "golden_cases": [
      {
        "name": "checkpoint_created_minimal",
