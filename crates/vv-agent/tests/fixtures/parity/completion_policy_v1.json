      "agent_policy": null,
      "runner_default_policy": "finish",
      "run_policy": "continue",
      "max_cycles": 2,
      "tool_use_behavior": "run_llm_again",
      "steps": [
        {
          "assistant_output": "keep going",
          "tool_calls": []
        },
        {
          "assistant_output": "",
          "tool_calls": [
            {
              "id": "finish-override",
              "name": "task_finish",
              "arguments": {
                "message": "override done"
              }
            }
          ]
