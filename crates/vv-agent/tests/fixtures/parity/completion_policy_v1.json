      "agent_policy": "finish",
      "runner_default_policy": null,
      "run_policy": null,
      "max_cycles": 3,
      "tool_use_behavior": "run_llm_again",
      "steps": [
        {
          "assistant_output": "natural answer",
          "tool_calls": []
        }
      ],
      "expected": {
        "effective_policy": "finish",
        "status": "completed",
        "completion_reason": "no_tool_finish",
        "completion_tool_name": null,
        "final_answer": "natural answer",
        "wait_reason": null,
        "partial_output": null,
        "cycles": 1,
        "continuation_hint_emitted": false
      }
    },
    {
