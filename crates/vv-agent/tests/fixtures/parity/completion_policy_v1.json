      "agent_policy": "finish",
      "runner_default_policy": null,
      "run_policy": "wait_user",
      "max_cycles": 3,
      "tool_use_behavior": "run_llm_again",
      "steps": [
        {
          "assistant_output": "need clarification",
          "tool_calls": []
        }
      ],
      "expected": {
        "effective_policy": "wait_user",
        "status": "wait_user",
        "completion_reason": "wait_user",
        "completion_tool_name": null,
        "final_answer": null,
        "wait_reason": "need clarification",
