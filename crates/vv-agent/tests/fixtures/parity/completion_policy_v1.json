        "wait_reason": null,
        "partial_output": null,
        "cycles": 2,
        "continuation_hint_emitted": true
      }
    },
    {
      "name": "runner_finish_overrides_agent_wait",
      "agent_policy": "wait_user",
      "runner_default_policy": "finish",
      "run_policy": null,
      "max_cycles": 2,
      "tool_use_behavior": "run_llm_again",
      "steps": [
        {
          "assistant_output": "runner wins",
          "tool_calls": []
        }
      ],
      "expected": {
        "effective_policy": "finish",
        "status": "completed",
        "completion_reason": "no_tool_finish",
        "completion_tool_name": null,
        "final_answer": "runner wins",
        "wait_reason": null,
        "partial_output": null,
        "cycles": 1,
        "continuation_hint_emitted": false
      }
    },
    {
      "name": "stop_on_first_tool",
      "agent_policy": null,
      "runner_default_policy": null,
      "run_policy": null,
      "max_cycles": 2,
      "tool_use_behavior": "stop_on_first_tool",
      "steps": [
        {
          "assistant_output": "using lookup",
          "tool_calls": [
            {
              "id": "lookup-first",
              "name": "lookup",
              "arguments": {}
            }
          ],
          "tool_results": [
            {
              "tool_call_id": "lookup-first",
              "content": "found",
              "directive": "continue"
            }
          ]
        }
      ],
      "expected": {
        "effective_policy": "continue",
        "status": "completed",
        "completion_reason": "stop_on_first_tool",
        "completion_tool_name": "lookup",
        "final_answer": "found",
        "wait_reason": null,
        "partial_output": null,
        "cycles": 1,
        "continuation_hint_emitted": false
      }
    },
    {
      "name": "stop_at_named_tool",
      "agent_policy": null,
      "runner_default_policy": null,
      "run_policy": null,
      "max_cycles": 2,
      "tool_use_behavior": "stop_at_tool_names",
      "stop_at_tool_names": [
        "lookup"
      ],
      "steps": [
        {
          "assistant_output": "using lookup",
          "tool_calls": [
            {
              "id": "lookup-named",
              "name": "lookup",
              "arguments": {}
            }
          ],
          "tool_results": [
            {
              "tool_call_id": "lookup-named",
