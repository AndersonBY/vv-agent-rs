{
  "version": 1,
  "policy_values": [
    "continue",
    "wait_user",
    "finish"
  ],
  "framework_default": "continue",
  "precedence": [
    "run_config",
    "runner_default_run_config",
    "agent",
    "framework_default"
  ],
  "completion_reason_values": [
    "tool_finish",
    "no_tool_finish",
    "stop_on_first_tool",
    "stop_at_tool_name",
    "wait_user",
    "max_cycles",
    "cancelled",
    "failed",
    "budget_exhausted"
  ],
  "rules": {
    "assistant_text_is_not_classified": true,
    "completion_policy_does_not_change_tool_availability": true,
    "explicit_tool_directive_precedes_no_tool_policy": true,
    "output_guardrail_failure_precedes_success_reason": true,
    "cancellation_precedes_generic_failure": true,
    "partial_output_only_for_non_completed_status": true,
    "budget_exhausted_is_defined_by_run_budget_v1": true,
    "approval_resume_uses_fresh_cycle_budget": true,
    "approval_resume_preserves_resource_budget": true,
    "approved_resume_rejects_input_before_claim": true,
    "pre_cancelled_approval_resume_skips_side_effects": true,
    "guardrail_allow_preserves_completion_observation": true,
    "ordinary_llm_failure_is_typed_terminal": true
  },
  "cases": [
    {
      "name": "framework_default_continues_then_tool_finishes",
      "agent_policy": null,
      "runner_default_policy": null,
      "run_policy": null,
      "max_cycles": 2,
      "tool_use_behavior": "run_llm_again",
      "steps": [
        {
          "assistant_output": "draft one",
          "tool_calls": []
        },
        {
          "assistant_output": "",
          "tool_calls": [
            {
              "id": "finish-2",
              "name": "task_finish",
              "arguments": {
                "message": "done"
              }
            }
          ]
        }
      ],
      "expected": {
        "effective_policy": "continue",
        "status": "completed",
        "completion_reason": "tool_finish",
        "completion_tool_name": "task_finish",
        "final_answer": "done",
        "wait_reason": null,
        "partial_output": null,
        "cycles": 2,
        "continuation_hint_emitted": true
      }
    },
    {
