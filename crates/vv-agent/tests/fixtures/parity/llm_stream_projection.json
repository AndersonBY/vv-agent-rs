{
  "schema_version": "vv-agent.llm-stream-projection.v1",
  "wire_version": "v1",
  "json_safe_integer_maximum": 9007199254740991,
  "adapter_boundary": {
    "visibility": "private",
    "input": "provider_adapter_payload",
    "output": "RunEvent",
    "public_raw_callback": false,
    "framework_identity_overrides_source": true,
    "unknown_source_event_policy": "drop",
    "invalid_known_event_policy": "drop",
    "lifecycle_shaped_source_event_policy": "drop"
  },
  "mappings": {
    "assistant_delta": {
      "wire_type": "assistant_delta",
      "required_source_field_alternatives": [
        [
          "content_delta",
          "delta"
        ]
      ],
      "optional_source_fields": [
        "content_chars",
        "estimated_tokens"
      ]
    },
    "reasoning_delta": {
      "wire_type": "reasoning_delta",
      "required_source_fields": [
        "reasoning_delta"
      ],
      "optional_source_fields": [
        "estimated_tokens",
        "reasoning_chars"
      ]
    },
    "tool_call_started": {
      "wire_type": "model_tool_call_started",
      "required_source_fields": [
        "function_name",
        "tool_call_id"
      ],
      "optional_source_fields": [
        "arguments_chars",
        "estimated_tokens",
        "tool_call_index"
      ]
    },
    "tool_call_progress": {
      "wire_type": "model_tool_call_progress",
      "required_source_fields": [
        "function_name",
        "tool_call_id"
      ],
      "optional_source_fields": [
        "arguments_chars",
        "estimated_tokens",
        "tool_call_index"
      ]
    }
  },
  "public_event_surface": {
    "observer": "RunConfig.stream",
    "observer_payload": "RunEvent",
    "observer_failure": "isolated",
    "typed_event_recorded_before_observer": true,
    "durable_replay": "RunEventStore",
    "raw_runtime_observer": false,
    "raw_provider_observer": false
  },
  "diagnostic_event": {
    "wire_type": "diagnostic",
    "required_fields": [
      "level",
      "code",
      "details"
    ],
    "levels": [
      "debug",
      "info",
      "warning",
      "error"
    ],
    "details_shape": "json_object_extension_map",
    "state_authority": false,
    "may_change_completion_or_tool_decisions": false,
    "raw_provider_payload_exposed": false
  },
  "scope_rules": {
    "top_level": {
      "identity_source": "runner_context",
      "metadata_policy": "typed_fields_only"
    },
    "configured_child": {
      "identity_source": "child_lifecycle",
      "cycle_source": "framework_injected_cycle",
      "metadata_policy": "canonical_child_payload",
      "private_receipt_fields_removed": true,
      "same_payload_mapping_as_top_level": true
    }
  },
  "consumer_policy": {
    "reasoning_is_visible_assistant_output": false,
    "model_tool_events_are_execution_events": false,
    "event_store_failure_uses_existing_policy": true,
    "observer_configuration_changes_runtime_decisions": false
  },
