    "expiry_cases": [
      {
        "name": "deadline_clamps_before_u64_addition",
        "now_ms": 1000,
        "lease_duration_ms": 18446744073709551615,
        "deadline_unix_ms": 1050,
        "expected_expiry_ms": 1050,
        "expected_error": null
      },
      {
        "name": "unbounded_u64_addition_overflows",
        "now_ms": 1000,
        "lease_duration_ms": 18446744073709551615,
        "deadline_unix_ms": null,
        "expected_expiry_ms": null,
        "expected_error": "checkpoint lease overflow"
      }
    ],
    "interval_lease_ms_cases": [
      1,
      2,
      10,
      30,
      3000,
      18446744073709551615
    ],
    "claim_boundary_case": {
      "claim_now_ms": 100,
      "lease_expires_at_ms": 200,
      "boundary_now_ms": 200,
      "owner_renewed": false,
      "contender_reclaimed": true
    },
    "worker_cases": [
      {
        "name": "initial_renewal_precedes_operation",
        "driver": {
          "initial_renewal": "success",
          "operation": "return",
          "commit": "success"
        },
        "expected": {
          "event_order": [
            "claim",
            "renew",
            "operation_start",
            "commit",
            "heartbeat_stop"
          ],
          "operation_calls": 1,
          "commit_calls": 1,
          "outcome": "success"
        }
      },
      {
        "name": "initial_renewal_failure_has_no_side_effects",
        "driver": {
          "initial_renewal": "claim_lost",
          "operation": "not_called",
          "commit": "not_called"
        },
        "expected": {
          "event_order": [
            "claim",
            "renew_failed"
          ],
          "cycle_calls": 0,
          "model_calls": 0,
          "tool_calls": 0,
          "commit_calls": 0,
          "outcome": "checkpoint lease heartbeat failed: claim is no longer active"
        }
      },
      {
        "name": "operation_unwind_stops_heartbeat",
        "driver": {
          "initial_renewal": "success",
          "operation": "unwind",
          "commit": "not_called"
        },
        "expected": {
          "event_order": [
            "claim",
            "renew",
            "operation_start",
            "operation_unwind",
            "heartbeat_stop"
          ],
          "renewals_after_stop": 0,
          "commit_calls": 0,
          "outcome": "unwind"
        }
      },
      {
        "name": "commit_barrier_keeps_heartbeat_active",
        "driver": {
          "initial_renewal": "success",
          "operation": "return",
          "commit": "blocked_then_success"
        },
        "expected": {
          "periodic_renewals_during_commit_min": 1,
          "contender_claimed": false,
          "commit_calls": 1,
          "outcome": "success"
        }
      },
      {
        "name": "successful_commit_beats_inflight_renewal_rejection",
        "driver": {
          "initial_renewal": "success",
          "operation": "return",
          "commit": "success_then_renew_rejected"
        },
        "expected": {
          "durable_commit": true,
          "heartbeat_error_suppressed": true,
          "outcome": "success"
        }
      }
    ]
  }
