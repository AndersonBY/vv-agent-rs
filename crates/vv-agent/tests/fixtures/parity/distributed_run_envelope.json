        "model_calls": 0,
        "tool_calls": 0
      }
    },
    {
      "name": "expired_started_unknown_tool",
      "expected": {
        "status": "reconciliation_required",
        "missing_reconciliation_provider_decision": "defer",
        "model_calls": 0,
        "tool_calls": 0
      }
    },
    {
      "name": "committed_receipt",
      "expected": {
        "operation_replayed": true,
        "external_calls": 0
      }
    },
    {
      "name": "committed_cycle",
      "expected": {
        "dispatch_cycle": 3,
        "next_envelope_claim_mode": "continue"
      }
    },
    {
      "name": "committed_terminal",
      "expected": {
        "terminal_replayed": true,
        "external_calls": 0
      }
    }
  ],
  "lease_lifecycle": {
    "rules": {
      "initial_expiry_capped_by_deadline": true,
      "renewed_expiry_capped_by_deadline": true,
      "initial_renewal_required_before_cycle": true,
