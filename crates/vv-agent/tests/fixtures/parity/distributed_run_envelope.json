      "heartbeat_active_through_commit": true,
      "operation_unwind_stops_heartbeat": true,
      "expired_owner_can_renew": false,
      "expired_claim_can_be_reclaimed": true,
      "heartbeat_interval_less_than_positive_lease": true,
      "successful_commit_precedes_concurrent_renewal_error": true
