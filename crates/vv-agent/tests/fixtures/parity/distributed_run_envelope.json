{
  "schema_version": "vv-agent.distributed-run.v2",
  "run_definition_schema_rules": {
    "writer_value": "vv-agent.run-definition.v1",
    "complete_definition_source": "embedded_run_definition_in_checkpoint",
    "envelope_digest_must_match_checkpoint_digest": true,
    "missing_or_unknown_error": "checkpoint_definition_schema_unsupported",
    "failure_boundary": "before_capability_resolution_or_claim"
  },
  "resume_attempt_rules": {
    "checkpoint_store_is_authoritative": true,
    "envelope_value_is_an_observation_not_an_increment_command": true,
    "continue_claim_preserves_value": true,
    "successful_recovery_claim_atomically_increments_store_and_next_envelope": true,
    "mismatch_error": "checkpoint_resume_attempt_mismatch"
  },
  "claim_mode_rules": {
    "wire_values": [
      "continue",
      "recovery"
    ],
    "initial_and_next_cycle_dispatch": "continue",
    "public_resume_and_explicit_redelivery": "recovery",
    "transport_redelivery_metadata_promotes_continue_to_recovery": true,
    "celery_source": "request.delivery_info.redelivered_or_retry_count",
    "apalis_source": "task_attempt_or_redelivery_metadata",
    "expired_claim_or_reconciliation_status_is_always_recovery": true,
    "missing_or_unknown_error": "checkpoint_claim_mode_invalid"
  },
