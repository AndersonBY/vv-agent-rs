      "session_add_items_once",
      "session_persisted_observation",
      "terminal_event_outbox_pending",
      "checkpoint_terminal_finalize",
      "terminal_event_delivery",
      "terminal_event_delivery_recorded",
      "terminal_acknowledge_retained",
      "scheduler_acknowledgement"
    ],
    "terminal_acknowledgement_does_not_delete": true,
    "apalis_blocking_runtime": "tokio_spawn_blocking"
  },
  "redelivery_cases": [
    {
      "name": "live_claim",
      "expected": {
        "status": "in_progress",
