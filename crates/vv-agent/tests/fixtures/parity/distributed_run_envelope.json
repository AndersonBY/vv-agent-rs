      "expected": {
        "error": "unknown distributed capability hook hook.missing@1",
        "claim_count": 0,
        "model_calls": 0,
        "tool_calls": 0
      }
    }
  ],
  "worker_rules": {
    "capability_resolution_before_claim": true,
    "resolved_tool_metadata_compared_with_embedded_definition_before_claim": true,
    "after_cycle_hook_resolution_before_claim": true,
    "metadata_tool_policy_fields_are_serialized_before_claim": true,
    "initial_claim_renewal_before_operations": true,
    "operation_progress_cas_preserves_claim": true,
    "heartbeat_updates_lease_only": true,
    "heartbeat_cannot_overwrite_journal": true,
    "reconciliation_provider_is_optional": true,
    "missing_reconciliation_provider_defaults_to_defer": true,
    "effective_claim_mode_uses_envelope_transport_metadata_and_stored_checkpoint": true,
    "terminal_commit_order": [
