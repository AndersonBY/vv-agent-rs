          {
            "content": "done",
            "tool_calls": []
          }
        ]
      },
      "expected": {
        "status": "completed",
        "completion_reason": "no_tool_finish",
        "checkpoint_key": null,
        "model_calls": 1,
        "checkpoint_events": []
      }
