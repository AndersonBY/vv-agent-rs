        "schema_version": "vv-agent.token-usage.v1",
        "input_tokens": 1000,
        "output_tokens": 120,
        "total_tokens": 1120,
        "reasoning_tokens": null,
        "usage_source": "provider_reported",
        "cache_usage": {
          "status": "provider_reported",
          "read_input_tokens": 640,
          "write_input_tokens": null,
          "uncached_input_tokens": 360,
          "source": "provider_usage"
        },
        "provider_usage": {
          "prompt_tokens": 1000,
          "completion_tokens": 120,
          "total_tokens": 1120,
          "prompt_tokens_details": {
            "cached_tokens": 640
          }
        }
      },
      "error_code": null
    }
  },
  "model_call_operations": [
    "agent_cycle",
    "session_memory",
    "memory_compaction"
  ],
  "model_call_statuses": [
    "completed",
    "failed",
    "ambiguous"
  ],
  "model_call_rules": {
    "call_id_unique_within_run": true,
    "record_scope": "locally_admitted_dispatch_attempt",
    "remote_provider_receipt_is_not_implied": true,
    "operation_id_stable_across_logical_retry": true,
    "attempt_is_one_based": true,
    "logical_retry_increments_attempt_and_changes_call_id": true,
    "durable_replay_adds_no_record": true,
    "provider_usage_captured_before_after_model_hook": true,
    "completed_error_code_is_null": true,
    "failed_or_ambiguous_error_code_is_non_empty": true,
    "failed_or_ambiguous_unknown_usage_makes_aggregate_unknown": true,
    "cycle_record_duplicates_usage": false,
    "prompts_outputs_and_error_bodies_are_forbidden": true
  },
  "task_usage_rules": {
    "schema_version": "vv-agent.task-token-usage.v2",
    "required_fields": [
      "schema_version",
      "input_tokens",
      "output_tokens",
      "total_tokens",
      "reasoning_tokens",
      "cache_usage",
      "model_calls"
    ],
    "unknown_fields_rejected": true,
    "model_calls_are_the_complete_durable_ledger_in_dispatch_order": true,
    "aggregate_fields_must_equal_model_calls": true,
    "duplicate_call_ids_rejected": true,
    "empty_ledger_has_exact_zero_token_totals": true,
    "failed_or_ambiguous_unknown_usage_makes_token_totals_null": true
  },
  "usage_sources": [
